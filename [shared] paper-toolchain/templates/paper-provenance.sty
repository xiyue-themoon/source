% ============================================================
% paper-provenance.sty — Watermark + Provenance Metadata
%
% Provides:
%   \provenanceauthor{NAME}     — author for watermark (big text)
%   \provenancealias{ALIAS}     — secondary name/handle
%   \provenanceemail{EMAIL}     — contact for footer
%   \provenancegit{HASH}        — git commit hash (from Makefile)
%   \provenancesubject{TEXT}    — PDF Subject metadata line
%
% Three protection layers:
%   1. Diagonal watermark across every page (eso-pic)
%   2. Footer copyright + git hash (fancyhdr)
%   3. PDF metadata via hyperref (Author / Subject)
%
% Usage with Route B (direct .tex):
%   \usepackage{paper-provenance}
%   \provenanceauthor{Zhenxuan Ma}
%   \provenancealias{XiYuE}
%   \provenanceemail{m2214349127@outlook.com}
%   \provenancegit{abc1234}          % auto from Makefile
%   \provenancesubject{Paper Title}
%   \provenancefooter                 % after \pagestyle{fancy}
%   \provenancemetadata               % after \hypersetup
%
% Usage with Route A (pandoc): YAML header-includes or
%   --include-in-header=paper-provenance-header.tex
%
% Dependencies: eso-pic, xcolor, graphicx, fancyhdr, hyperref
% All are LaTeX base / common — no extra MiKTeX packages.
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{paper-provenance}[2026/07/19 v1.1 Paper provenance & dual-signature watermark]

\RequirePackage{eso-pic}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{fancyhdr}
\RequirePackage{hyperref}

% ---- Configurable fields ----
\newcommand{\pv@author}{Author}
\newcommand{\pv@alias}{}
\newcommand{\pv@email}{}
\newcommand{\pv@git}{unknown}
\newcommand{\pv@subject}{}
\newcommand{\pv@year}{\the\year}

\newcommand{\provenanceauthor}[1]{\renewcommand{\pv@author}{#1}}
\newcommand{\provenancealias}[1]{\renewcommand{\pv@alias}{#1}}
\newcommand{\provenanceemail}[1]{\renewcommand{\pv@email}{#1}}
\newcommand{\provenancegit}[1]{\renewcommand{\pv@git}{#1}}
\newcommand{\provenancesubject}[1]{\renewcommand{\pv@subject}{#1}}

% ---- Derived: full signature for watermark / footer ----
\newcommand{\pv@signature}{\pv@author\ifx\pv@alias\empty\else\ \textperiodcentered\ \pv@alias\fi}

% ---- Layer 1: Diagonal watermark on every page ----
\AddToShipoutPicture{%
    \AtTextCenter{%
        \makebox[0pt][c]{%
            \rotatebox{45}{%
                \textcolor[gray]{0.82}{\fontsize{48}{60}\selectfont\pv@signature}%
            }%
        }%
    }%
}

% ---- Layer 2: Footer provenance line ----
\newcommand{\provenancefooter}{%
    \fancyfoot[L]{\tiny
        \textcopyright\ \pv@year\ \pv@signature
        \ifx\pv@email\empty\else\ | \pv@email\fi
        \ | commit:\pv@git
    }%
}

% ---- Layer 3: PDF metadata (invisible in file properties) ----
\newcommand{\provenancemetadata}{%
    \hypersetup{%
        pdfauthor={\pv@signature\ifx\pv@email\empty\else\ (\pv@email)\fi},
        pdfsubject={\pv@subject\ | git:\pv@git\ | compiled \today},
    }%
}

\endinput
